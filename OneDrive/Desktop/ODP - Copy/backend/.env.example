NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/online_donation_platform

# JWT (access token — keep SHORT, e.g. 15m)
JWT_SECRET=replace_with_a_strong_secret_min_32_chars
JWT_EXPIRES_IN=15m

# Refresh token (days)
REFRESH_TOKEN_DAYS=30

# CSRF (can reuse JWT_SECRET or set a separate one)
CSRF_SECRET=replace_with_another_strong_secret

# Frontend origin (used for CORS + email links)
FRONTEND_URL=http://localhost:5500

# Razorpay
RAZORPAY_KEY_ID=replace_with_razorpay_key_id
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_razorpay_webhook_secret

# Email (Resend)
RESEND_API_KEY=replace_with_resend_api_key
FROM_EMAIL=OpenDonate <noreply@yourdomain.com>

# Default admin seed
DEFAULT_ADMIN_NAME=Platform Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=Admin@12345
SYNC_DEFAULT_ADMIN_CREDENTIALS=false
